# Cerebro Environment Variables

# Claude API (required)
ANTHROPIC_API_KEY=your-api-key-here

# Database (optional — defaults to data/cerebro.db)
# CEREBRO_DB_PATH=/path/to/cerebro.db

# API Server (optional)
# CEREBRO_API_HOST=0.0.0.0
# CEREBRO_API_PORT=8000

# Frontend URL for CORS (optional)
# CEREBRO_FRONTEND_URL=http://localhost:3000
